NODE_ENV=production
HOST=0.0.0.0
PORT=8787
APP_BASE_URL=https://leona-lab.com
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook Stripe (Dashboard → Developers → Webhooks → endpoint https://leona-lab.com/api/stripe/webhook)
# Evento: checkout.session.completed
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Email post-acquisto (Resend). Senza RESEND_API_KEY il pagamento funziona comunque, ma non parte l'email custom.
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Leona.Lab <noreply@tuodominio.com>
# Optional: allow free signup even with Stripe key present
# ALLOW_FREE_REGISTER=true
# Admin emails: free lifetime registration (comma-separated)
# ADMIN_EMAILS=admin1@example.com,admin2@example.com
# Desk data APIs require login + payment proof when Stripe is enabled.
# Optional: allow weak seed user in production (default: off)
# ALLOW_SEED_USER=true
# Optional: one-shot admin password bootstrap (set, redeploy, then REMOVE)
# ADMIN_BOOTSTRAP_PASSWORD=cambia-questa-password
# Optional: fixed per-email admin passwords (comma-separated email:password)
# ADMIN_FIXED_PASSWORDS=admin@example.com:PasswordSicura1!
# Optional custom data directory (use with Railway volume)
# DATA_DIR=/data
# Sessions persist under DATA_DIR/sessions.json
